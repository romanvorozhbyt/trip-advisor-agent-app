{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.SemanticKernel": "Debug",
        "TripAdvisorAgent": "Debug",
        "System.Net.Http.HttpClient": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Debug",
      "TripAdvisorAgent.WebApi.Middleware.RequestResponseLoggingMiddleware": "Debug"
    }
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=tripadvisor.db"
  },
  "Qdrant": {
    "Host": "localhost",
    "Port": 6334,
    "UseHttps": false
  },
  "AirLabs": {
    "ApiKey": ""
  },
  "FlightSearch": {
    "Provider": "AirLabs"
  },
  "News": {
    "FetchIntervalHours": 1,
    "MaxItemsPerFeed": 5,
    "ArticleMaxLength": 800,
    "RssFeeds": [
      "https://travel.state.gov/content/travel/en/traveladvisories/traveladvisories.rss.xml",
      "https://feeds.bbci.co.uk/news/world/rss.xml",
      "https://www.aljazeera.com/xml/rss/all.xml",
      "https://rss.nytimes.com/services/xml/rss/nyt/World.xml",
      "https://www.theguardian.com/world/rss"
    ]
  }
}

